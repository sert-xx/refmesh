{
  "name": "refmesh",
  "version": "0.1.0",
  "description": "Knowledge graph construction CLI for autonomous coding agents, backed by Kùzu local graph database.",
  "type": "module",
  "bin": {
    "refmesh": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run build:console",
    "build:console": "node scripts/build-console-ui.mjs",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src test console-ui",
    "lint:fix": "biome check --write src test console-ui",
    "format": "biome format --write src test console-ui",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p console-ui/tsconfig.json --noEmit",
    "prepare": "npm run build"
  },
  "keywords": [
    "knowledge-graph",
    "kuzu",
    "cli",
    "agent",
    "memory",
    "rag"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sert-xx/refmesh.git"
  },
  "bugs": {
    "url": "https://github.com/sert-xx/refmesh/issues"
  },
  "homepage": "https://github.com/sert-xx/refmesh#readme",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.27.2",
    "@xenova/transformers": "^2.17.2",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "commander": "^12.1.0",
    "kuzu": "^0.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.9.0",
    "cytoscape": "^3.30.4",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
